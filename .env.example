# CrewSwarm / OpenClaw environment variables
# Copy to .env and fill in. Keys can also be set in Dashboard → Providers.

# RT message bus (required if using gateway-bridge / agent daemons)
OPENCREW_RT_AUTH_TOKEN=
OPENCREW_RT_URL=ws://127.0.0.1:18889

# crew-lead (chat commander)
CREW_LEAD_PORT=5010
CREW_LEAD_MODEL=groq/llama-3.3-70b-versatile
CREW_LEAD_WORKSPACE=

# Dashboard
SWARM_DASH_PORT=4319
SWARM_PASSWORD=

# Config paths (defaults: ~/.openclaw, ~/.crewswarm)
OPENCREWHQ_CONFIG_DIR=
OPENCLAW_DIR=

# Optional: provider keys (or set in Dashboard → Providers)
# GROQ_API_KEY=
# BRAVE_API_KEY=
# PARALLEL_API_KEY=

# PM Loop
OPENCREW_OUTPUT_DIR=
# PM_ROADMAP_FILE=./ROADMAP.md

# Telegram bridge
# TELEGRAM_BOT_TOKEN=

# OpenCode (optional)
# OPENCODE_URL=http://127.0.0.1:4096
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=
