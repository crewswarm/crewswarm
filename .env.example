# CrewSwarm environment variables
# Copy to .env and fill in values you want to override.
#
# Most config lives in ~/.crewswarm/ — you don't need this file to run CrewSwarm.
# Use it only to override defaults or for CI/server deployments.

# ── RT message bus ────────────────────────────────────────────────────────────
# Auto-read from ~/.crewswarm/config.json → rt.authToken if not set here
OPENCREW_RT_AUTH_TOKEN=
OPENCREW_RT_URL=ws://127.0.0.1:18889

# ── crew-lead ─────────────────────────────────────────────────────────────────
CREW_LEAD_PORT=5010

# ── Dashboard ─────────────────────────────────────────────────────────────────
SWARM_DASH_PORT=4319
# SWARM_PASSWORD=

# ── Config paths (defaults shown — only set to override) ─────────────────────
# CREWSWARM_DIR=~/.crewswarm
# OPENCLAW_DIR=~/.openclaw   (legacy fallback only)

# ── PM loop ───────────────────────────────────────────────────────────────────
# OPENCREW_OUTPUT_DIR=
# PM_ROADMAP_FILE=./ROADMAP.md

# ── Telegram bridge ───────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── Groq fallback model (used when primary provider fails) ───────────────────
# GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# ── OpenCode (optional — not required for normal operation) ───────────────────
# OPENCODE_URL=http://127.0.0.1:4096
# OPENCREW_OPENCODE_ENABLED=0

# ── Provider API keys ─────────────────────────────────────────────────────────
# Preferred: set these in ~/.crewswarm/crewswarm.json → providers
# or via Dashboard → Providers tab.
# Only use env vars here for CI/server deployments without a config file.
#
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# PERPLEXITY_API_KEY=
# CEREBRAS_API_KEY=
# XAI_API_KEY=
