# CrewSwarm — environment variable reference
#
# Copy to .env and fill in values, OR set these in the dashboard
# under Settings → Security → Environment Variables.
# Values set in ~/.crewswarm/crewswarm.json (env block) take precedence.
#
# API keys and secrets belong in ~/.crewswarm/crewswarm.json, not here.
# See: https://github.com/your-org/crewswarm#setup

# ── Ports ────────────────────────────────────────────────────────────────────
# CREW_LEAD_PORT=5010
# SWARM_DASH_PORT=4319
# WA_HTTP_PORT=3000

# ── Engine — OpenCode ────────────────────────────────────────────────────────
# CREWSWARM_OPENCODE_ENABLED=1
# CREWSWARM_OPENCODE_MODEL=anthropic/claude-sonnet-4-5
# CREWSWARM_OPENCODE_TIMEOUT_MS=300000
# CREWSWARM_OPENCODE_AGENT=

# ── Engine — Claude Code & Cursor ────────────────────────────────────────────
# Both use OAuth login — no API key needed.
# Run `claude` or `cursor` once on the host to authenticate.
# CREWSWARM_CLAUDE_CODE_MODEL=
# CREWSWARM_CURSOR_MODEL=

# ── Engine — Docker Sandbox ──────────────────────────────────────────────────
# Requires Docker Desktop with Sandboxes enabled.
# Create once: docker sandbox create --name crewswarm shell <project-dir>
# CREWSWARM_DOCKER_SANDBOX=1
# CREWSWARM_DOCKER_SANDBOX_NAME=crewswarm
# CREWSWARM_DOCKER_SANDBOX_INNER_ENGINE=claude
# CREWSWARM_DOCKER_SANDBOX_TIMEOUT_MS=300000

# ── Engine Loop (Ouroboros) ──────────────────────────────────────────────────
# CREWSWARM_ENGINE_LOOP=1
# CREWSWARM_ENGINE_LOOP_MAX_ROUNDS=10
# CREWSWARM_DISPATCH_TIMEOUT=120000

# ── Background Consciousness ─────────────────────────────────────────────────
# CREWSWARM_BG_CONSCIOUSNESS=1
# CREWSWARM_BG_CONSCIOUSNESS_INTERVAL_MS=900000
# CREWSWARM_BG_CONSCIOUSNESS_MODEL=groq/llama-3.1-8b-instant

# ── Messaging ────────────────────────────────────────────────────────────────
# TELEGRAM_ALLOWED_USERNAMES=yourusername
# WA_ALLOWED_NUMBERS=+15551234567

# ── PM Loop ──────────────────────────────────────────────────────────────────
# PM_MAX_ITEMS=10
# PM_USE_QA=1
# PM_USE_SECURITY=1
