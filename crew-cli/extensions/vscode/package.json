{
  "name": "crewswarm",
  "displayName": "crewswarm",
  "description": "crewswarm: Multi-agent AI coding assistant with chat-based code generation and QA loop",
  "version": "0.1.0",
  "publisher": "crewswarm",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Snippets"
  ],
  "activationEvents": [
    "onCommand:crewswarm.openChat",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "crewswarm.openChat",
        "title": "crewswarm: Open Chat",
        "category": "crewswarm"
      },
      {
        "command": "crewswarm.askCrew",
        "title": "crewswarm: Ask Crew",
        "category": "crewswarm"
      },
      {
        "command": "crewswarm.refreshConnection",
        "title": "crewswarm: Refresh Connection",
        "category": "crewswarm"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "crewswarm.askCrew",
          "when": "editorHasSelection",
          "group": "crewswarm"
        }
      ],
      "editor/title": [
        {
          "command": "crewswarm.openChat",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "crewswarm.openChat",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "crewswarm",
      "properties": {
        "crewswarm.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:4319/v1",
          "description": "crewswarm API base URL (use /v1 endpoint for crewswarm backend)"
        },
        "crewswarm.authToken": {
          "type": "string",
          "default": "",
          "description": "Authentication token for crewswarm API (optional)"
        },
        "crewswarm.mode": {
          "type": "string",
          "enum": ["connected", "standalone"],
          "default": "connected",
          "description": "Runtime mode: connected (full crewswarm) or standalone"
        },
        "crewswarm.sessionId": {
          "type": "string",
          "default": "vscode-extension",
          "description": "Session identifier for tracking conversations"
        },
        "crewswarm.enableTelemetry": {
          "type": "boolean",
          "default": true,
          "description": "Enable telemetry and usage analytics"
        },
        "crewswarm.timeout": {
          "type": "number",
          "default": 30000,
          "description": "API request timeout in milliseconds"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && npx @vscode/test-electron ./test/test-runner.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "glob": "^10.3.12",
    "mocha": "^10.4.0",
    "typescript": "^5.4.5",
    "@vscode/test-electron": "^2.3.8"
  }
}
