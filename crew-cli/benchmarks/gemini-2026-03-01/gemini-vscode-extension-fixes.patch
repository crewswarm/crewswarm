-    // You might want to add logic here to reveal the webview if it's hidden.
-    vscode.commands.executeCommand(`${ChatWebviewProvider.viewType}.focus`);
+    panel.webview.html = getWebviewHtml(panel, context.extensionPath);
+
+    panel.webview.onDidReceiveMessage(async (message) => {
+      if (message?.command === 'sendMessage') {
+        try {
+          const response = await apiClient.sendMessage(String(message.text || ''));
+          panel.webview.postMessage({ command: 'response', text: response.reply || '' });
+
+          const firstPatch = Array.isArray(response.patches) ? response.patches[0] : undefined;
+          if (firstPatch?.unifiedDiff) {
+            panel.webview.postMessage({ command: 'diffResponse', text: firstPatch.unifiedDiff });
+          }
+        } catch (error) {
+          const msg = (error as Error)?.message || String(error);
+          panel.webview.postMessage({ command: 'response', text: `Error: ${msg}` });
+        }
+        return;
+      }
+
+      if (message?.command === 'applyDiff') {
+        const diffText = String(message.diff || '');
+        await diffHandler.applyDiff(diffText);
+      }
+    });
   });
 
   context.subscriptions.push(disposable);
 }
 
 export function deactivate() {}
+
+function getWebviewHtml(panel: vscode.WebviewPanel, extensionPath: string): string {
+  const htmlPath = path.join(extensionPath, 'src', 'webview', 'chat.html');
+  const scriptPath = path.join(extensionPath, 'src', 'webview', 'chat.js');
+  const stylesPath = path.join(extensionPath, 'src', 'webview', 'styles.css');
+
+  let html = fs.readFileSync(htmlPath, 'utf8');
+  const scriptUri = panel.webview.asWebviewUri(vscode.Uri.file(scriptPath));
+  const stylesUri = panel.webview.asWebviewUri(vscode.Uri.file(stylesPath));
+  const nonce = String(Date.now()) + String(Math.floor(Math.random() * 1e9));
+
+  html = html.replace('${script}', scriptUri.toString());
+  html = html.replace('${styles}', stylesUri.toString());
+  html = html.replaceAll('${nonce}', nonce);
+  html = html.replace('${cspSource}', panel.webview.cspSource);
+
+  return html;
+}
