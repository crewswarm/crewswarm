{
  "name": "crewswarm-cli",
  "version": "0.1.0-alpha",
  "description": "Command-line interface for CrewSwarm agent orchestration",
  "type": "module",
  "main": "dist/crew.mjs",
  "bin": {
    "crew": "bin/crew.js"
  },
  "scripts": {
    "start": "node bin/crew.js",
    "build": "esbuild src/cli/index.ts --bundle --platform=node --format=esm --target=node20 --sourcemap --outfile=dist/crew.mjs --packages=external",
    "test": "node --import tsx --test tests/*.test.js",
    "check": "npm run build && node --check dist/crew.mjs",
    "doctor": "node bin/crew.js doctor"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "commander": "^11.0.0",
    "diff": "^8.0.3",
    "dotenv": "^16.3.0",
    "inquirer": "^9.2.0",
    "ora": "^7.0.1",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "esbuild": "^0.25.0",
    "eslint": "^8.50.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
