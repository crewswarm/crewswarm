{
  "openapi": "3.1.0",
  "info": {
    "title": "Crew Unified Interface API",
    "version": "1.0.0",
    "description": "Unified contract for dashboard-first (connected) and standalone/headless modes."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5010",
      "description": "Connected mode (crew-lead)"
    },
    {
      "url": "http://127.0.0.1:4317",
      "description": "Standalone mode (recommended local adapter port)"
    }
  ],
  "tags": [
    { "name": "Chat" },
    { "name": "Tasks" },
    { "name": "Agents" },
    { "name": "Sandbox" },
    { "name": "Trace" },
    { "name": "Index" },
    { "name": "System" }
  ],
  "paths": {
    "/v1/chat": {
      "post": {
        "tags": ["Chat"],
        "summary": "Submit a user message through unified L1/L2/L3 flow",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChatRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChatResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/tasks": {
      "post": {
        "tags": ["Tasks"],
        "summary": "Create an agent task",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TaskCreateRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Task accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskCreateResponse" }
              }
            }
          },
          "200": {
            "description": "Task accepted (legacy status code)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskCreateResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{taskId}": {
      "get": {
        "tags": ["Tasks"],
        "summary": "Get task status/result",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Task status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskStatusResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/agents": {
      "get": {
        "tags": ["Agents"],
        "summary": "List available agents",
        "responses": {
          "200": {
            "description": "Agent list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AgentsResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/status": {
      "get": {
        "tags": ["System"],
        "summary": "Get interface/system status",
        "responses": {
          "200": {
            "description": "Status payload",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SystemStatusResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/sandbox": {
      "get": {
        "tags": ["Sandbox"],
        "summary": "Get sandbox branch + diff preview",
        "responses": {
          "200": {
            "description": "Sandbox state",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SandboxStateResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/sandbox/apply": {
      "post": {
        "tags": ["Sandbox"],
        "summary": "Apply sandbox changes to filesystem",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SandboxApplyRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Apply result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SandboxApplyResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/sandbox/rollback": {
      "post": {
        "tags": ["Sandbox"],
        "summary": "Discard sandbox changes",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SandboxRollbackRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rollback result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SandboxRollbackResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/traces/{traceId}": {
      "get": {
        "tags": ["Trace"],
        "summary": "Get composed prompt/planner trace",
        "parameters": [
          {
            "name": "traceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Trace payload",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TraceResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/index/rebuild": {
      "post": {
        "tags": ["Index"],
        "summary": "Rebuild local docs/code index",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/IndexRebuildRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rebuild result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IndexRebuildResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/index/search": {
      "get": {
        "tags": ["Index"],
        "summary": "Search local index",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Search result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IndexSearchResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatRequest": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "sessionId": { "type": "string" },
          "context": {
            "type": "object",
            "properties": {
              "files": {
                "type": "array",
                "items": { "type": "string" }
              },
              "docs": { "type": "boolean" }
            },
            "additionalProperties": true
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "data": { "type": "string" },
                "mimeType": { "type": "string" }
              },
              "required": ["data", "mimeType"]
            }
          },
          "mode": { "type": "string" }
        },
        "required": ["message"]
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "reply": { "type": "string" },
          "traceId": { "type": "string" },
          "executionPath": {
            "type": "array",
            "items": { "type": "string" }
          },
          "costUsd": { "type": "number" },
          "pendingChanges": { "type": "integer" }
        },
        "required": ["reply"]
      },
      "TaskCreateRequest": {
        "type": "object",
        "properties": {
          "agent": { "type": "string" },
          "task": { "type": "string" },
          "sessionId": { "type": "string" },
          "options": {
            "type": "object",
            "properties": {
              "model": { "type": "string" },
              "engine": { "type": "string" },
              "gateway": { "type": "string" },
              "direct": { "type": "boolean" },
              "bypass": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        },
        "required": ["agent", "task"]
      },
      "TaskCreateResponse": {
        "type": "object",
        "properties": {
          "accepted": { "type": "boolean" },
          "taskId": { "type": "string" }
        },
        "required": ["accepted"]
      },
      "TaskStatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["queued", "running", "done", "error"]
          },
          "result": {},
          "traceId": { "type": "string" },
          "costUsd": { "type": "number" },
          "error": { "type": "string" }
        },
        "required": ["status"]
      },
      "AgentsResponse": {
        "type": "object",
        "properties": {
          "agents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "status": { "type": "string" },
                "model": { "type": "string" },
                "role": { "type": "string" }
              },
              "required": ["id"]
            }
          }
        },
        "required": ["agents"]
      },
      "SystemStatusResponse": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["connected", "standalone"] },
          "gateway": { "type": "string" },
          "l2": {
            "type": "object",
            "properties": {
              "unifiedRouter": { "type": "boolean" },
              "dualL2": { "type": "boolean" }
            }
          },
          "queueDepth": { "type": "integer" }
        },
        "required": ["mode"]
      },
      "SandboxStateResponse": {
        "type": "object",
        "properties": {
          "branch": { "type": "string" },
          "changedFiles": { "type": "integer" },
          "diffPreview": { "type": "string" }
        },
        "required": ["branch", "changedFiles"]
      },
      "SandboxApplyRequest": {
        "type": "object",
        "properties": {
          "branch": { "type": "string" },
          "checkCommand": { "type": "string" }
        }
      },
      "SandboxApplyResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "appliedFiles": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["success"]
      },
      "SandboxRollbackRequest": {
        "type": "object",
        "properties": {
          "branch": { "type": "string" }
        }
      },
      "SandboxRollbackResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" }
        },
        "required": ["success"]
      },
      "TracePromptItem": {
        "type": "object",
        "properties": {
          "templateId": { "type": "string" },
          "templateVersion": { "type": "string" },
          "composedAt": { "type": "string" },
          "overlays": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "priority": { "type": "integer" }
              }
            }
          }
        }
      },
      "TraceResponse": {
        "type": "object",
        "properties": {
          "composedPrompts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TracePromptItem" }
          },
          "plannerTrace": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TracePromptItem" }
          },
          "events": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "IndexRebuildRequest": {
        "type": "object",
        "properties": {
          "paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "includeDocs": { "type": "boolean" },
          "includeCode": { "type": "boolean" }
        }
      },
      "IndexRebuildResponse": {
        "type": "object",
        "properties": {
          "indexId": { "type": "string" },
          "stats": {
            "type": "object",
            "properties": {
              "files": { "type": "integer" },
              "chunks": { "type": "integer" }
            }
          }
        }
      },
      "IndexSearchHit": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "score": { "type": "number" },
          "snippet": { "type": "string" }
        },
        "required": ["path", "score"]
      },
      "IndexSearchResponse": {
        "type": "object",
        "properties": {
          "hits": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IndexSearchHit" }
          }
        },
        "required": ["hits"]
      }
    }
  }
}
