{
  "id": "claude-code",
  "label": "Claude Code",
  "description": "Route tasks through Anthropic's Claude Code CLI (claude -p). Full workspace context, native tool use, and session continuity per agent. Best for large refactors and multi-file reasoning.",
  "shouldUse": {
    "runtime": ["claude", "claude-code"],
    "payloadKey": "useClaudeCode",
    "agentConfigKey": "useClaudeCode",
    "envVar": "CREWSWARM_CLAUDE_CODE"
  },
  "bin": "claude",
  "binAlternate": "~/.local/bin/claude",
  "installCmd": "npm install -g @anthropic-ai/claude-code",
  "installUrl": "https://claude.ai/code",
  "docsUrl": "https://docs.anthropic.com/claude-code",
  "color": "#d4a853",
  "icon": "claude",
  "agentConfigKey": "useClaudeCode",
  "envToggle": "CREWSWARM_CLAUDE_CODE",
  "requiresAuth": true,
  "authNote": "Uses OAuth — run `claude` once to authenticate. No API key needed. Set ANTHROPIC_API_KEY only if you prefer API-key mode.",
  "modelEnvVar": "CREWSWARM_CLAUDE_CODE_MODEL",
  "modelFlag": "--model",
  "bestFor": ["crew-coder", "crew-fixer", "crew-coder-back"],
  "traits": [
    "Full workspace context at every call",
    "Native Anthropic tool use (no @@TOOL parsing)",
    "Session continuity per agent ID",
    "OAuth auth — no API key required"
  ],
  "args": {
    "run": ["-p", "--dangerously-skip-permissions", "{prompt}"],
    "run_with_model": ["-p", "--dangerously-skip-permissions", "--model", "{model}", "{prompt}"]
  },
  "outputMode": "stream-json"
}
