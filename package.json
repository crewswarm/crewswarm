{
  "name": "crewswarm",
  "version": "0.1.0",
  "description": "PM-led multi-agent orchestration for software development. One requirement in, real files out.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dashboard": "node scripts/dashboard.mjs",
    "crew-lead": "node crew-lead.mjs",
    "pm-loop": "node pm-loop.mjs",
    "gateway": "node gateway-bridge.mjs",
    "telegram": "node telegram-bridge.mjs",
    "whatsapp": "node whatsapp-bridge.mjs",
    "start-crew": "node scripts/start-crew.mjs",
    "rt-daemon": "node scripts/opencrew-rt-daemon.mjs",
    "restart-all": "bash scripts/restart-all-from-repo.sh",
    "crew-cli": "node crew-cli.mjs",
    "smoke:dispatch": "node scripts/smoke-dispatch.mjs",
    "smoke:e2e": "node scripts/crewswarm-flow-test.mjs",
    "smoke": "npm run smoke:dispatch && npm run smoke:e2e",
    "improvement:baseline": "node scripts/improvement-baseline-test.mjs",
    "mcp": "node scripts/mcp-server.mjs",
    "mcp:stdio": "node scripts/mcp-server.mjs --stdio",
    "health": "node scripts/health-check.mjs",
    "test:mcp": "node scripts/test-mcp.mjs --start",
    "test:classifier": "node scripts/test-classifier.mjs",
    "test:classifier:e2e": "node scripts/test-classifier.mjs --e2e",
    "test:all": "npm run health && npm run smoke && npm run test:mcp && npm run test:classifier"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcrypt": "^6.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "eslint": "^10.0.2"
  }
}
