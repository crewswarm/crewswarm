{
  "name": "crewswarm",
  "version": "0.1.0",
  "description": "PM-led multi-agent orchestration for software development. One requirement in, real files out.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dashboard": "node scripts/dashboard.mjs",
    "crew-lead": "node crew-lead.mjs",
