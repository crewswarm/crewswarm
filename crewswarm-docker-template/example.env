# CrewSwarm Template Environment Configuration

# ── Model Provider API Keys ──────────────────────────────────────────────────
# At least one is required. Groq offers free tier with good performance.

# OpenAI (GPT-4, GPT-4o, GPT-3.5)
OPENAI_API_KEY=

# Groq (Fast, free tier available)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Mistral
MISTRAL_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# ── Database Configuration ───────────────────────────────────────────────────
# Leave defaults for Docker Compose setup
DB_HOST=crewswarm-db
DB_PORT=5432
DB_USER=crewswarm
DB_PASS=crewswarm
DB_DATABASE=crewswarm

# ── Service Ports ────────────────────────────────────────────────────────────
CREW_LEAD_PORT=5010
SWARM_DASH_PORT=4319

# ── Optional Features ────────────────────────────────────────────────────────
# Enable background consciousness (crew-main runs periodic reflection)
# CREWSWARM_BG_CONSCIOUSNESS=1
# CREWSWARM_BG_CONSCIOUSNESS_INTERVAL_MS=900000

# Enable OpenCode engine routing for coding agents
# CREWSWARM_OPENCODE_ENABLED=1

# ── Telegram Integration (Optional) ──────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_TARGET_AGENT=crew-lead

# ── WhatsApp Integration (Optional) ──────────────────────────────────────────
# WA_ALLOWED_NUMBERS=+15551234567,+15559876543
